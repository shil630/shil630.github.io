#!/usr/bin/env bash
# 本地预览博客。保存 Markdown 后刷新浏览器即可看到改动。
set -euo pipefail
cd "$(dirname "$0")"

if command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init - bash 2>/dev/null || rbenv init - zsh)" || true
fi
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

ensure_deps() {
  if bundle exec jekyll --version >/dev/null 2>&1; then
    return 0
  fi
  echo "依赖不可用（常见于换电脑或 iCloud 同步后），正在运行 ./setup …"
  echo ""
  ./setup
}

DRAFT_FLAG=()
if [[ "${1:-}" == "--draft" ]] || [[ "${1:-}" == "-d" ]]; then
  DRAFT_FLAG=(--drafts)
  shift
fi

ensure_deps

echo "→ http://localhost:4000"
[[ ${#DRAFT_FLAG[@]} -gt 0 ]] && echo "→ 草稿模式已开启（含 _drafts/）"
echo "→ 改完文章保存，等终端出现 regenerate 后刷新页面"
echo ""

exec bundle exec jekyll serve --livereload ${DRAFT_FLAG[@]+"${DRAFT_FLAG[@]}"} "$@"
